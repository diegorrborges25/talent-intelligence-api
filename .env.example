# ==========================================================================
# Talent Intelligence API — variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# A API roda sem nenhuma alteração; todos os valores abaixo têm default seguro.
# ==========================================================================

# --- Aplicação ---
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true
# Caminho do banco SQLite (criado e populado automaticamente no 1º start).
DATABASE_PATH=talent.db

# --- Segurança / Autenticação (JWT) ---
# IMPORTANTE: em produção troque por um segredo longo e aleatório.
JWT_SECRET_KEY=troque-este-segredo-em-producao-por-uma-string-aleatoria-longa
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Usuário de demonstração (criado no seed). Senha é hasheada com PBKDF2.
DEMO_USERNAME=recruiter
DEMO_PASSWORD=talent123

# --- Rate limiting (proteção básica) ---
RATE_LIMIT_PER_MINUTE=60

# --- LLM opcional (Claude / Anthropic) ---
# Deixe em branco para rodar 100% offline (motor de regras + similaridade).
# Se preenchido E a lib `anthropic` estiver instalada, o parsing é
# enriquecido por LLM com fallback automático em caso de erro.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
